{
  "functions": {
    "src/app/api/photos/upload/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/galleries/[galleryId]/download/worker/route.ts": {
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/cron/reminders",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/scheduled-emails",
      "schedule": "0 9 * * *"
    }
  ]
}
